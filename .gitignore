# ==========================================
# 3DCPP ENGINE GITIGNORE
# ==========================================

# --- CMake and Build Artifacts ---
# Ignore the build directory so we don't commit compiled binaries and caches
build/
.cache/
compile_commands.json
CMakeCache.txt
CMakeFiles/
Makefile
cmake_install.cmake

# --- Compiled Binaries & Intermediates ---
# Ignore raw executables and object files
*.exe
*.o
*.a
*.so
*.out
*.app
*.glb
*.gltf

# --- Shader Artifacts ---
# Ignore compiled SPIR-V binaries and generated headers 
# (These are generated automatically during the CMake build process)
*.spv
*_spv.h

# --- IDE Settings ---
# Ignore local editor configurations
.vscode/
.idea/
*.suo
*.sln
*.user

# ==========================================
# NOTE ON VENDOR AND TOOLS:
# We explicitly DO NOT ignore the `vendor/` or `tools/` directories here.
# This ensures all your external C++ libraries (GLFW, ImGui, Jolt, cgltf, VMA) 
# and the local DXC compiler are successfully pushed to Git.
# Anyone who clones this repo can build it instantly without downloading dependencies!
# ==========================================